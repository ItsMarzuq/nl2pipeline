# Kafka
KAFKA_BOOTSTRAP=kafka:9092
KAFKA_TOPIC=gdelt-events

# Producer
PRODUCER_MODE=replay
PUBLISH_RATE=10
DATA_PATH=/data/gdelt
REPLAY_LOOP=true

# Live mode
LIVE_POLL_SECONDS=900

# Downloader
# Use a small range for testing first.
START_DATE=20240601000000
END_DATE=20240601010000

# Logging
LOG_LEVEL=INFO

# Consumer test
CONSUMER_MAX_MESSAGES=10