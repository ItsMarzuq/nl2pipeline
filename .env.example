KAFKA_BROKER_ID=1
KAFKA_HOST=nl2pipeline-kafka:9092
KAFKA_EXTERNAL_PORT=29092
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1

CASSANDRA_CLUSTER_NAME=nl2pipeline
CASSANDRA_PORT=9042

SPARK_MASTER_WEBUI_PORT=8081
SPARK_MASTER_PORT=7077
SPARK_WORKER_WEBUI_PORT=8082
SPARK_WORKER_MEMORY=2g
SPARK_WORKER_CORES=2

ZOOKEEPER_CLIENT_PORT=2181

# Backend / SLM inference
BACKEND_PORT=8000
# Ollama model tag to pull and serve (see `ollama-pull` service in docker-compose.yaml).
# Swap to a custom tag (e.g. from `ollama create`) once a fine-tuned checkpoint is ready.
OLLAMA_MODEL=qwen3.5:4b
MAX_NEW_TOKENS=1024
OLLAMA_NUM_CTX=6144
MAX_ATTEMPTS=3

# Ollama server tuning (VRAM-constrained GPUs) — see ollama service in docker-compose.yaml
OLLAMA_FLASH_ATTENTION=1
OLLAMA_KV_CACHE_TYPE=q8_0
OLLAMA_KEEP_ALIVE=30m